{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-cluster.example/contracts/agent-roles.schema.json",
  "title": "Agent Roles",
  "description": "Schema for agent-roles.riido.json. Each role declares allowed_paths and forbidden_paths globs plus PR-isolation rules. agentguard enforces these per-PR; probe preflight runs ValidateRoles to catch typos and malformed globs before they cause silent role lookups to return nil.",
  "type": "object",
  "required": ["version", "owner", "roles"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "owner": {
      "type": "string",
      "enum": ["agent-cluster-contracts"]
    },
    "description": { "type": "string" },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/role" }
    }
  },
  "$defs": {
    "role": {
      "type": "object",
      "required": [
        "id",
        "label",
        "description",
        "allowed_paths",
        "forbidden_paths",
        "pr_isolation"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "decision": {
          "type": "string",
          "pattern": "^[0-9]{3}-[a-z0-9][a-z0-9-]*$"
        },
        "allowed_paths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "forbidden_paths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "pr_isolation": {
          "type": "object",
          "required": ["candidate_only", "guard_only"],
          "additionalProperties": false,
          "properties": {
            "candidate_only": { "type": "boolean" },
            "guard_only": { "type": "boolean" },
            "rationale": { "type": "string" }
          }
        },
        "max_files_per_pr": { "type": "integer", "minimum": 1 },
        "auto_merge_eligible": { "type": "boolean" },
        "auto_merge_paths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
