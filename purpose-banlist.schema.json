{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-cluster.example/contracts/purpose-banlist.schema.json",
  "title": "Fixture purpose banlist",
  "type": "object",
  "required": ["version", "owner", "banned"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "owner": { "type": "string", "enum": ["agent-cluster-contracts"] },
    "description": { "type": "string" },
    "banned": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["normalized", "seeded_by_decision", "reason"],
        "additionalProperties": false,
        "properties": {
          "normalized": { "type": "string", "minLength": 1 },
          "seeded_by_decision": {
            "type": "string",
            "pattern": "^[0-9]{3}-[a-z0-9][a-z0-9-]*$"
          },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
